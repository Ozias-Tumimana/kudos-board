// Kudos Board — Prisma schema
// Implements Section 3 (Database Schema Spec) of planning.md.
// Board (1) ──< (many) Card, with cascade delete.
// Stretch (M3): User (auth), Comment, plus pin fields and user ownership.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Board {
  id        Int      @id @default(autoincrement())
  title     String
  category  String // celebration / thank-you / inspiration
  author    String?
  imageUrl  String? // placeholder default applied in the app layer
  createdAt DateTime @default(now()) // used for the "Recent" filter
  cards     Card[]

  // Stretch (auth): optional owner. Null = guest/anonymous board.
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Card {
  id        Int      @id @default(autoincrement())
  message   String
  gifUrl    String // from GIPHY
  author    String?
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  boardId   Int
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // Stretch (pinned cards): pinned floats to the top; pinnedAt orders pins.
  pinned   Boolean   @default(false)
  pinnedAt DateTime?

  // Stretch (auth): optional owner. Null = guest card.
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Stretch (comments): a card has many comments; cascade-delete with the card.
  comments Comment[]
}

// Stretch (auth): a registered user. passwordHash is bcrypt and never returned.
model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  boards       Board[]
  cards        Card[]
  comments     Comment[]
}

// Stretch (comments): a comment on a card. author is free-text for guests;
// userId links to a User when the comment was posted while logged in.
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  author    String?
  createdAt DateTime @default(now())
  cardId    Int
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
